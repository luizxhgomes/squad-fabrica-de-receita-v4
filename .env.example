# .env.example, Squad Fábrica de Receita
#
# Copie este arquivo para .env e preencha com as SUAS chaves.
# O .gitignore ja protege .env de ser commitado. NUNCA coloque chave real aqui.
# Se uma chave vazar, rotacione imediatamente no painel do provedor.
#
# Estas integracoes sao OPCIONAIS: o squad opera sem elas. Preencha apenas
# as que a sua operacao usar. Todas as ferramentas sao consumidas via MCP
# no Claude Code, nao pelo squad diretamente.

# Analytics
GOOGLE_ANALYTICS_4_PROPERTY_ID=your-ga4-property-id
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Midia paga
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-token

# CRM e automacao
HUBSPOT_API_KEY=your-hubspot-key
RDSTATION_TOKEN=your-rdstation-token

# Outras
CALENDLY_TOKEN=your-calendly-token
METRICOOL_TOKEN=your-metricool-token
